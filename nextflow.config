/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    RNABioInfo/mcaat-nf Nextflow config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Default config options for all compute environments.

    This pipeline is built WITH the nf-core template but is NOT an nf-core
    pipeline. It must never be referred to as `nf-core/mcaat-nf`.
----------------------------------------------------------------------------------
*/

params {

    // ------------------------------------------------------------------------
    // Input / output options
    // ------------------------------------------------------------------------
    input                        = null
    outdir                       = null
    email                        = null
    multiqc_title                = null

    // ------------------------------------------------------------------------
    // Read QC options
    //   All QC steps are ON by default, hence `skip_*`.
    // ------------------------------------------------------------------------
    skip_qc                      = false
    skip_fastqc                  = false
    skip_fastp                   = false
    fastp_save_trimmed_fail      = false
    save_trimmed_reads           = false
    host_fasta                   = null
    host_bowtie2_index           = null
    save_hostremoved_reads       = false
    remove_phix                  = false
    // Bundled with the pipeline: NCBI NC_001422.1 (Escherichia phage phiX174,
    // 5386 bp, public domain), gzipped. BBDuk builds a k-mer table from this
    // file, so it must stay a SMALL contaminant genome -- never point it at a
    // mammalian reference.
    phix_reference               = "${projectDir}/assets/phix174.fasta.gz"
    subsample_reads              = null
    subsample_seed               = 100
    skip_pairsync_check          = false

    // ------------------------------------------------------------------------
    // MCAAT options
    //   NOTE: k (23) and min-kmer-frequency (1) are HARD-CODED in the MCAAT
    //   graph build and are deliberately not exposed. Neither are --ram,
    //   --threads, --autoclean, --settings, --benchmark or the dead
    //   --graph-folder / --cycles-folder / --output-file flags.
    // ------------------------------------------------------------------------
    mcaat_min_spacer_len         = 23
    mcaat_max_spacer_len         = 50
    mcaat_min_repeat_len         = 23
    mcaat_max_repeat_len         = 55
    mcaat_cycle_min_length       = 27
    mcaat_cycle_max_length       = 77
    mcaat_threshold_multiplicity = 20
    mcaat_low_abundance          = true
    mcaat_keep_graph             = true
    prune_graph                  = true
    save_mcaat_graph             = false
    graph_publish_mode           = 'symlink'
    save_mcaat_cycles            = false
    mcaat_scratch                = null
    mcaat_args                   = null
    mcaat_container              = 'docker.io/feeka94/mcaat:1.0.1'

    // ------------------------------------------------------------------------
    // Stage activation (optional, experimental stages -- OFF by default)
    // ------------------------------------------------------------------------
    run_phage_curation           = false

    // ------------------------------------------------------------------------
    // Phage curation options
    //   Intentionally near-empty: every phage tunable in MCAAT is either
    //   hard-coded or accepted-and-never-read.
    // ------------------------------------------------------------------------
    save_phage_log               = false

    // ------------------------------------------------------------------------
    // Reporting options
    //   Both cohort thresholds are read by modules/local/cohort_summarise and
    //   rendered onto the bin/mcaat_aggregate.py command line, so they must
    //   stay declared here (and in nextflow_schema.json) with exactly the
    //   defaults the module falls back to.
    // ------------------------------------------------------------------------
    skip_cohort_aggregation      = false
    skip_multiqc                 = false
    cohort_min_spacer_sharing    = 2
    cohort_min_spacer_redundancy = 2
    multiqc_config               = null
    multiqc_logo                 = null
    multiqc_methods_description  = null

    // ------------------------------------------------------------------------
    // Institutional config options
    // ------------------------------------------------------------------------
    custom_config_version        = 'master'
    custom_config_base           = "https://raw.githubusercontent.com/nf-core/configs/${params.custom_config_version}"
    config_profile_name          = null
    config_profile_description   = null
    config_profile_contact       = null
    config_profile_url           = null

    // ------------------------------------------------------------------------
    // Generic options
    // ------------------------------------------------------------------------
    help                         = false
    help_full                    = false
    show_hidden                  = false
    version                      = false
    validate_params              = true
    monochrome_logs              = false
    publish_dir_mode             = 'copy'
    email_on_fail                = null
    plaintext_email              = false
    hook_url                     = null
    trace_report_suffix          = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')
    // NOTE: this repository DOES NOT EXIST YET. It has to be created and
    // populated before any `-profile test*` run can succeed. See CHANGELOG.md
    // and docs/usage.md.
    pipelines_testdata_base_path = 'https://raw.githubusercontent.com/RNABioInfo/mcaat-nf-testdata/main/'
    modules_testdata_base_path   = 's3://ngi-igenomes/testdata/nf-core/modules/'
}

// Load base.config by default for all pipelines
includeConfig 'conf/base.config'

profiles {
    debug {
        dumpHashes              = true
        process.beforeScript    = 'echo $HOSTNAME'
        cleanup                 = false
        nextflow.enable.configProcessNamesValidation = true
    }
    conda {
        // NOTE: MCAAT has no Bioconda recipe, so the
        // MCAAT processes have no `conda` directive and this profile cannot run
        // the array/phage stages. It is kept for the QC and reporting layers.
        conda.enabled           = true
        conda.channels          = ['conda-forge', 'bioconda']
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    mamba {
        conda.enabled           = true
        conda.useMamba          = true
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    docker {
        docker.enabled          = true
        conda.enabled           = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
        docker.runOptions       = '-u $(id -u):$(id -g)'
    }
    arm {
        // MCAAT is linux/amd64 ONLY (megahit rank/select relies on
        // __builtin_popcount lowering; spoa pulls <immintrin.h>). On an ARM
        // host the images are run under emulation, which is slow but correct.
        docker.runOptions       = '-u $(id -u):$(id -g) --platform=linux/amd64'
        singularity.runOptions  = '--env LD_BIND_NOW=1'
    }
    singularity {
        singularity.enabled     = true
        singularity.autoMounts  = true
        conda.enabled           = false
        docker.enabled          = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    podman {
        podman.enabled          = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        shifter.enabled         = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    shifter {
        shifter.enabled         = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        charliecloud.enabled    = false
        apptainer.enabled       = false
    }
    charliecloud {
        charliecloud.enabled    = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        apptainer.enabled       = false
    }
    apptainer {
        apptainer.enabled       = true
        apptainer.autoMounts    = true
        conda.enabled           = false
        docker.enabled          = false
        singularity.enabled     = false
        podman.enabled          = false
        shifter.enabled         = false
        charliecloud.enabled    = false
    }
    wave {
        apptainer.ociAutoPull   = true
        singularity.ociAutoPull = true
        wave.enabled            = true
        wave.freeze             = true
        wave.strategy           = 'conda,container'
    }
    gitpod {
        executor.name           = 'local'
        executor.cpus           = 4
        executor.memory         = 8.GB
        process {
            resourceLimits = [
                memory: 8.GB,
                cpus  : 4,
                time  : 1.h
            ]
        }
    }

    // -- Test profiles --------------------------------------------------------
    // Every one of these resolves its samplesheet from
    // `params.pipelines_testdata_base_path`, which points at a repository that
    // does not exist yet (see the note on that param above).
    test       { includeConfig 'conf/test.config'       }
    test_phage { includeConfig 'conf/test_phage.config' }
    test_graph { includeConfig 'conf/test_graph.config' }
    test_full  { includeConfig 'conf/test_full.config'  }
}

// Load nf-core custom profiles from different institutions.
// The pipeline is not an nf-core pipeline, so only the generic institutional
// profiles are loaded -- there is no pipeline-specific config in nf-core/configs.
includeConfig !System.getenv('NXF_OFFLINE') && params.custom_config_base ? "${params.custom_config_base}/nfcore_custom.config" : "/dev/null"

// Load modules.config for DSL2 module specific options
includeConfig 'conf/modules.config'

// Set default registry for Apptainer, Docker, Podman, Charliecloud and
// Singularity independent of -profile
apptainer.registry    = 'quay.io'
docker.registry       = 'quay.io'
podman.registry       = 'quay.io'
singularity.registry  = 'quay.io'
charliecloud.registry = 'quay.io'

// Export these variables to prevent local Python/R libraries from conflicting
// with those in the container. LC_ALL is C.UTF-8 because MCAAT writes a literal
// em-dash into every CRISPR_Arrays_*.txt header, which a C locale mangles on
// read-back.
env {
    PYTHONNOUSERSITE = 1
    R_PROFILE_USER   = "/.Rprofile"
    R_ENVIRON_USER   = "/.Renviron"
    JULIA_DEPOT_PATH = "/usr/local/share/julia"
    LC_ALL           = "C.UTF-8"
    LANG             = "C.UTF-8"
}

// Set bash options
process.shell = [
    "bash",
    "-C",         // No clobber - prevent output redirection from overwriting files.
    "-e",         // Exit if a tool returns a non-zero status/exit code.
    "-u",         // Treat unset variables and parameters as an error.
    "-o",         // Returns the status of the last command to exit..
    "pipefail"    //   ..with a non-zero status or zero if all successfully execute.
]

// Disable process selector name validation warnings for the optional stages,
// whose selectors legitimately match nothing when the stage is switched off.
nextflow.enable.configProcessNamesValidation = false

timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline_${params.trace_report_suffix}.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report_${params.trace_report_suffix}.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace_${params.trace_report_suffix}.txt"
}
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag_${params.trace_report_suffix}.html"
}

manifest {
    name            = 'RNABioInfo/mcaat-nf'
    contributors    = [
        [
            name         : 'Fikrat Talibli',
            affiliation  : 'RNA Bioinformatics, University of Stuttgart',
            email        : 'fikrattalibli@gmail.com',
            github       : 'https://github.com/feeka94',
            contribution : ['author', 'maintainer'],
            orcid        : ''
        ]
    ]
    homePage        = 'https://github.com/RNABioInfo/mcaat-nf'
    description     = """CRISPR array and protospacer discovery directly in unassembled metagenomic reads, powered by MCAAT."""
    mainScript      = 'main.nf'
    defaultBranch   = 'main'
    nextflowVersion = '!>=25.10.4'
    version         = '1.0.0dev'
    doi             = ''
}

// Nextflow plugins
plugins {
    id 'nf-schema@2.5.1'    // Validation of pipeline parameters and creation of an input channel from a sample sheet
}

validation {
    defaultIgnoreParams = []
    monochromeLogs      = params.monochrome_logs
    help {
        enabled             = true
        command             = "nextflow run RNABioInfo/mcaat-nf -profile <docker/singularity/.../institute> --input samplesheet.csv --outdir <OUTDIR>"
        fullParameter       = "help_full"
        showHiddenParameter = "show_hidden"
        beforeText = """
-\033[2m----------------------------------------------------\033[0m-
                                        \033[0;32m,--.\033[0;30m/\033[0;32m,-.\033[0m
\033[0;34m        ___     ___   __   __   __\033[0m   \033[0;32m/,-._.--~'\033[0m
\033[0;34m  |    |   |   |     |__| |__| |__|\033[0m \033[0;33m}  {\033[0m
\033[0;34m  \\___ |   |   |___  |    |    |   \033[0m \033[0;32m\\`-._,-`-,\033[0m
                                        \033[0;32m`._,._,'\033[0m
\033[0;35m  RNABioInfo/mcaat-nf ${manifest.version}\033[0m
-\033[2m----------------------------------------------------\033[0m-
"""
        afterText = """${manifest.doi ? "\n* The pipeline\n" : ""}${manifest.doi.tokenize(",").collect { "    https://doi.org/${it.trim().replace('https://doi.org/','')}" }.join("\n")}${manifest.doi ? "\n" : ""}
* MCAAT, the tool this pipeline orchestrates
    https://doi.org/10.1093/femsml/uqaf016

* The nf-core framework, whose template and tooling this pipeline uses
    https://doi.org/10.1038/s41587-020-0439-x

* Software dependencies
    https://github.com/RNABioInfo/mcaat-nf/blob/main/CITATIONS.md

  NOTE: mcaat-nf is built with the nf-core template but is NOT an nf-core
  pipeline. Please do not refer to it as nf-core/mcaat-nf.
"""
    }
    summary {
        beforeText = validation.help.beforeText
        afterText  = validation.help.afterText
    }
}
