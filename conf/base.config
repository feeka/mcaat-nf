/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    RNABioInfo/mcaat-nf Nextflow base config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    A 'blank slate' config file, appropriate for general use on most high
    performance compute environments. Assumes that all software is installed and
    available on the PATH. Runs in `local` mode - all jobs will be run on the
    logged in environment.
--------------------------------------------------------------------------------
*/

process {

    // Generic defaults for anything that carries no label.
    cpus   = { 1 * task.attempt }
    memory = { 6.GB * task.attempt }
    time   = { 4.h * task.attempt }

    // Default nf-core retry window. NOTE: this deliberately includes 130..145,
    // which covers SIGABRT (134). MCAAT's release main() aborts on every CLI and
    // validation error, so the MCAAT processes REPLACE this strategy with a much
    // narrower one in conf/modules.config (see the withName block there).
    errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : 'finish' }
    maxRetries    = 1
    maxErrors     = '-1'

    // ------------------------------------------------------------------------
    // Standard nf-core resource labels
    // ------------------------------------------------------------------------
    withLabel: process_single {
        cpus   = { 1 }
        memory = { 6.GB * task.attempt }
        time   = { 4.h * task.attempt }
    }
    withLabel: process_low {
        cpus   = { 2 * task.attempt }
        memory = { 12.GB * task.attempt }
        time   = { 4.h * task.attempt }
    }
    withLabel: process_medium {
        cpus   = { 6 * task.attempt }
        memory = { 36.GB * task.attempt }
        time   = { 8.h * task.attempt }
    }
    withLabel: process_high {
        cpus   = { 12 * task.attempt }
        memory = { 72.GB * task.attempt }
        time   = { 16.h * task.attempt }
    }
    withLabel: process_long {
        time = { 20.h * task.attempt }
    }
    withLabel: process_high_memory {
        memory = { 200.GB * task.attempt }
    }
    withLabel: error_ignore {
        errorStrategy = 'ignore'
    }
    withLabel: error_retry {
        errorStrategy = 'retry'
        maxRetries    = 2
    }

    // ------------------------------------------------------------------------
    // MCAAT-specific resource labels
    // ------------------------------------------------------------------------
    //
    // Two facts drive every number below:
    //
    //  1. `--ram` behaviour depends on the MCAAT image. In 1.0.0 the flag is
    //     ignored: `Settings::ram` is a GB figure handed to megahit's
    //     byte-valued `--host_mem` (src/core/sdbg_build.cpp:209), so a 72 GB
    //     request arrives as a 72-byte budget. That is fixed in the pinned
    //     1.0.1 image, where megahit honours the value.
    //
    //     The module derives `--ram` inside the task from the cgroup memory
    //     limit (v2 memory.max, then v1 memory.limit_in_bytes, then
    //     /proc/meminfo), clamped to a >=2 GB floor. /proc/meminfo alone is not
    //     sufficient: it reports HOST memory inside a container, which since
    //     1.0.1 would hand megahit a budget larger than the container's limit.
    //     The clamp also keeps MCAAT's two validation traps (`ram <= 1.0` and
    //     `ram > host total`, both of which route into an interactive stdin
    //     prompt) unreachable.
    //
    //     `--ram` is not interpolated from `task.memory`: that would put the
    //     memory directive into the task hash, so retuning these labels would
    //     invalidate every cached MCAAT_RUN. Reading the limit at runtime gives
    //     the same number without affecting the hash.
    //
    //     `memory` here remains an OOM-kill ceiling enforced by the cgroup or
    //     scheduler and must be sized empirically -- see the calibration
    //     procedure in docs/usage.md.
    //
    //  2. `cpus` IS FIXED AND IS NEVER ESCALATED ON RETRY. CycleFinder allocates
    //     a visited bitset of (nodes+63)/64 words PER THREAD
    //     (src/crispr_array/cycle_finder.cpp:600-610), i.e. task.cpus x edges/8
    //     bytes, entirely outside any accounting. Escalating cpus on an OOM
    //     retry makes the OOM strictly worse. Only `memory` and `time` scale.
    //     8 also sits below the ~24-core scaling plateau measured in
    //     docs/report.md:75, and three phases are single-threaded regardless
    //     (RecursiveReduction over all tips, per-bucket bitset zeroing, and the
    //     whole SPOA post-processing stage).
    //
    //     Fixing cpus additionally pins the SDBG shard count (the number of
    //     graph.sdbg.<N> files equals --num_cpu_threads), which keeps -resume
    //     hashes and output declarations stable across profiles.
    //
    withLabel: process_mcaat_run {
        cpus   = { 8 }
        memory = { 72.GB * task.attempt }
        time   = { 16.h * task.attempt }
    }

    // Phage curation is an uncapped recursive DFS followed by two O(n^2)
    // std::search subpath filters, with no candidate cap and no wall-clock
    // budget. Wall time is the binding constraint, not memory.
    withLabel: process_phage {
        cpus   = { 4 }
        memory = { 48.GB * task.attempt }
        time   = { 24.h * task.attempt }
    }
}
