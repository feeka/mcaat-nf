/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for the SDBG graph re-entry path
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Feeds a PRE-BUILT, pruned MCAAT SDBG straight to the optional stage,
    skipping read QC and array detection entirely for that sample.

    Use as follows:
        nextflow run RNABioInfo/mcaat-nf -profile test_graph,<docker/singularity> --outdir <OUTDIR>

    The samplesheet for this profile carries rows with an `sdbg` column and no
    `fastq_1`. Per the samplesheet contract, such a row is only meaningful when
    an optional stage is enabled AND the matching CRISPR_Arrays_*.txt from the
    original run are available: PIPELINE_INITIALISATION resolves them by
    convention from `<sdbg>/../CRISPR_Arrays_*.txt`, i.e. the sibling of the
    graph/ directory inside a published <outdir>/arrays/<sample>/, and throws a
    named error if none are found. Graph re-entry is a RE-ANALYSIS path over a
    prior published run, not a way to start from a foreign graph.

    What it is here to prove:
      * the graph is consumed as a DIRECTORY, never as a shard glob -- the number
        of graph.sdbg.<N> files equals --num_cpu_threads, so any enumerated
        declaration breaks the moment task.cpus changes;
      * the `test -s <graph>/graph.sdbg_info` guard in the subcommand module --
        the subcommand does not validate its --graph path, and SDBG::LoadFromFile
        on a stale or wrong path yields undefined behaviour on a
        default-constructed metadata object rather than a clean error;
      * that OMP_NUM_THREADS is the ONLY bound on thread count in --graph mode,
        because omp_set_num_threads() is never called on that path at all.

    NOTE -- THIS PROFILE CANNOT RUN YET, for the same reason as `-profile test`:
    `params.pipelines_testdata_base_path` points at
    https://raw.githubusercontent.com/RNABioInfo/mcaat-nf-testdata/main/, which
    has still to be created and populated. See CHANGELOG.md and docs/usage.md.

--------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus  : 4,
        memory: '15.GB',
        time  : '1.h'
    ]
}

params {
    config_profile_name        = 'Graph re-entry test profile'
    config_profile_description = 'Pre-built SDBG fed directly to the optional stage, skipping array detection'

    // A samplesheet containing at least one `sdbg` re-entry row alongside a
    // normal read row, so both branches of the initialisation split are covered
    // in a single run.
    input = params.pipelines_testdata_base_path + 'mcaat-nf/samplesheet/samplesheet_graph.csv'

    subsample_reads = 2000
    subsample_seed  = 100

    // --- stage activation ----------------------------------------------------
    // Phage curation is the stage exercised here: it is the only graph-consuming
    // optional stage the pipeline wraps, and it needs no third-party asset.
    run_phage_curation = true

    // Required for the read-derived sample in the same samplesheet; the
    // re-entry row supplies its graph from disk and never runs the build.
    mcaat_keep_graph = true

    save_phage_log = true
}
