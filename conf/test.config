/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline
    test.

    Use as follows:
        nextflow run RNABioInfo/mcaat-nf -profile test,<docker/singularity> --outdir <OUTDIR>

    NOTE -- THIS PROFILE CANNOT RUN YET. `params.pipelines_testdata_base_path`
    defaults to https://raw.githubusercontent.com/RNABioInfo/mcaat-nf-testdata/main/,
    and that repository does not exist. It has to be created and populated with
    the layout referenced below before `-profile test` will resolve anything.
    Until then every test profile fails at samplesheet fetch. See CHANGELOG.md
    and docs/usage.md.

--------------------------------------------------------------------------------
*/

// The GitHub Actions budget, and a HARD design constraint on the test data:
// an SDBG build over a real metagenome will not fit here, so the test reads are
// tiny synthetic libraries carrying a planted CRISPR array.
process {
    resourceLimits = [
        cpus  : 4,
        memory: '15.GB',
        time  : '1.h'
    ]
}

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Input data
    // 2 paired-end samples (one split across two lanes, to exercise CAT_FASTQ)
    // + 1 single-end sample, one of which deliberately yields ZERO arrays so the
    // header-only normalisation, the always-emitted *_mqc.tsv and the zero-row
    // cohort handling are all covered.
    input = params.pipelines_testdata_base_path + 'mcaat-nf/samplesheet/samplesheet.csv'

    // --- read QC -----------------------------------------------------------
    // Everything in the QC chain stays ON: the pair-sync gate in particular is
    // the construct most worth exercising, because the failure it prevents
    // (odd combined PE read count -> megahit xfatal) presents as exit 1 with a
    // completely empty .command.err.
    subsample_reads = 2000
    subsample_seed  = 100

    // --- MCAAT -------------------------------------------------------------
    // Defaults are used deliberately. `mcaat_keep_graph` is left at its default
    // (true) so that -profile test and -profile test_phage resolve to the SAME
    // MCAAT_RUN task hash and share the cache; overriding it here would force a
    // full graph rebuild for the optional-stage profile.
    //
    // No MCAAT tuning params are set: the planted array is 12 copies of a 32 bp
    // repeat at 40x coverage, which clears the default
    // --threshold-multiplicity 20 with margin.

    // --- reporting ---------------------------------------------------------
    // Cohort aggregation and MultiQC both stay on -- they are the cross-sample
    // products this pipeline exists for, and the nf-test assertions read them.
}
