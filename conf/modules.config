/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.

    Every `withName:` selector in this file names a process that actually exists
    in the pipeline. That is not cosmetic: a selector matching nothing is
    SILENTLY INERT, and because the process-scope default below is
    `publishDir = [enabled: false]`, a stale selector does not error -- it just
    disables publishing and quietly reverts the process to base.config's wide
    130..145 retry window.

    THERE IS NO AUTOMATIC SAFETY NET FOR THIS. `nextflow.config` sets
    `nextflow.enable.configProcessNamesValidation = false` unconditionally, and
    that assignment sits AFTER the `profiles` block, so it also overrides the
    `true` set inside `-profile debug`. The switch is off deliberately and
    permanently: several selectors here legitimately match nothing on a given
    run (MCAAT_PHAGECURATE whenever `run_phage_curation` is false; the FASTQC /
    FASTP / SEQKIT_STATS selectors under `--skip_qc`; CSVTK_CONCAT,
    SEQKIT_RMDUP and COHORT_SUMMARISE under `--skip_cohort_aggregation`), and
    leaving validation on would emit a wall of warnings on every ordinary run.

    So selector drift has to be caught by hand. When a process is renamed,
    added or removed, re-check this file against the names the pipeline can
    actually resolve -- the declared process names PLUS the `include { X as Y }`
    aliases, because `withName:` matches the alias a process is invoked under,
    not the name in its module file:

        grep -rhoE '^process [A-Z0-9_]+' modules/ | sed 's/process //'
        grep -rhoE ' as +[A-Z0-9_]+' workflows/ subworkflows/ | sed 's/ as //'

    Every `withName:` string below must appear in the union of those two lists
    (an `A|B` alternation selector expands to one name per branch). As of this
    writing the only alias-only selectors are FASTQC_RAW and FASTQC_TRIMMED,
    both aliases of nf-core FASTQC in subworkflows/local/read_qc.
--------------------------------------------------------------------------------
*/

process {

    // Nothing is published unless a process explicitly opts in below. This is
    // deliberate: MCAAT's work directories contain tens of GB of megahit
    // intermediates and a catch-all default publishDir would copy them out.
    publishDir = [
        enabled: false
    ]

    // ========================================================================
    // Read QC
    // ========================================================================

    withName: 'CAT_FASTQ' {
        ext.prefix = { "${meta.id}" }
        // Lane-merged FASTQ is a pure intermediate; the trimmed/QC'd reads are
        // the publishable artefact (and only when explicitly requested).
        publishDir = [
            enabled: false
        ]
    }

    withName: 'FASTQC_RAW' {
        ext.args   = '--quiet'
        ext.prefix = { "${meta.id}_raw" }
        publishDir = [
            path: { "${params.outdir}/qc/fastqc/raw/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.{html,zip}"
        ]
    }

    withName: 'FASTP' {
        // Strict paired-end trimming. Merging is hard-wired off at the call
        // site (save_merged = false) because a merged single file would break
        // MCAAT's token-count paired-end inference; --detect_adapter_for_pe is
        // what keeps R1/R2 record counts equal, which the pair-sync gate then
        // asserts before anything is dispatched to MCAAT.
        ext.args   = '--detect_adapter_for_pe'
        ext.prefix = { "${meta.id}" }
        publishDir = [
            [
                path: { "${params.outdir}/qc/fastp/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: "*.{json,html,log}"
            ],
            [
                path: { "${params.outdir}/qc/fastp/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: "*.fastp.fastq.gz",
                enabled: params.save_trimmed_reads
            ],
            [
                path: { "${params.outdir}/qc/fastp/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: "*.fail.fastq.gz",
                enabled: params.fastp_save_trimmed_fail
            ]
        ]
    }

    withName: 'BOWTIE2_BUILD' {
        // Built once per run into a value channel; never published.
        publishDir = [
            enabled: false
        ]
    }

    withName: 'BOWTIE2_ALIGN' {
        // Host depletion: we consume .out.fastq (the UNALIGNED reads), so the
        // module is called with save_unaligned = true and sort_bam = false.
        ext.args   = '--very-sensitive-local'
        ext.prefix = { "${meta.id}.hostremoved" }
        publishDir = [
            [
                path: { "${params.outdir}/qc/bowtie2/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: "*.log"
            ],
            [
                path: { "${params.outdir}/qc/bowtie2/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: "*.fastq.gz",
                enabled: params.save_hostremoved_reads
            ]
        ]
    }

    withName: 'BBMAP_BBDUK' {
        // phiX / small-contaminant scrub only. The reference is supplied as the
        // second input channel (params.phix_reference). NEVER point this at a
        // mammalian genome -- the k-mer table will not fit in the JVM heap.
        ext.args   = 'k=31 hdist=1'
        ext.prefix = { "${meta.id}.phixremoved" }
        publishDir = [
            path: { "${params.outdir}/qc/bbduk/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.log"
        ]
    }

    withName: 'SEQTK_SAMPLE' {
        // The seed MUST be identical for both mates; that is the only thing
        // preserving pairing through subsampling.
        //
        // THE LEADING SPACE IS LOAD-BEARING. The nf-core module guards against a
        // missing seed with `if (!(args ==~ /.*\ -s\ ?[0-9]+.*/)) { args += " -s100" }`,
        // and that regex requires a literal space before `-s`. Rendered as
        // "-s42" the guard does not match, the module appends " -s100", seqtk is
        // invoked as `sample -s42 -s100 ...`, and its getopt loop lets the LAST
        // -s win -- so every run silently used seed 100 and params.subsample_seed
        // was a no-op for every value except its own default.
        ext.args   = { " -s${params.subsample_seed}" }
        ext.prefix = { "${meta.id}.subsampled" }
        publishDir = [
            enabled: false
        ]
    }

    withName: 'FASTQC_TRIMMED' {
        ext.args   = '--quiet'
        ext.prefix = { "${meta.id}_trimmed" }
        publishDir = [
            path: { "${params.outdir}/qc/fastqc/trimmed/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.{html,zip}"
        ]
    }

    withName: 'SEQKIT_STATS' {
        // '--all' is what yields Q20/Q30/GC for MultiQC; the module itself only
        // passes --tabular. The num_seqs column is also what the pair-sync gate
        // reads, so this process must never be skipped when MCAAT runs on a pair.
        ext.args   = '--all'
        ext.prefix = { "${meta.id}" }
        publishDir = [
            path: { "${params.outdir}/qc/seqkit/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.tsv"
        ]
    }

    // ========================================================================
    // MCAAT processes -- shared directives
    // ========================================================================
    //
    // scratch: MCAAT writes --output-folder RELATIVE to the task CWD, so
    // relocating the CWD does relocate every intermediate (outfile_prefix.bin,
    // the SDBG shards, cycles.txt). Off by default because not every site
    // provisions node-local scratch.
    //
    // containerOptions: transitional shim for docker.io/feeka94/mcaat:1.0.0,
    // which sets ENTRYPOINT ["mcaat"]. Under the Docker executor that turns
    // Nextflow's `/bin/bash -ue .command.sh` into ARGUMENTS to mcaat, which the
    // parse loop silently discards before aborting with 134 -- and the bug is
    // invisible under Singularity, which ignores the entrypoint. Harmless
    // no-op against the pipeline-owned image; kept so a user overriding
    // `container` with the upstream image still works.
    //
    // errorStrategy: DELIBERATELY NARROWER than the nf-core default. The default
    // retries 130..145, which includes SIGABRT (134) -- and MCAAT aborts with
    // 134 on every deterministic CLI/validation error, so the default would burn
    // 4x walltime on a typo. The module scripts remap the two cases that matter
    // (std::bad_alloc -> 137 retryable, runtime_error/invalid_argument -> 64
    // terminal) by grepping the tool's own log, then fall through to the raw
    // status. Not retried: 1 (megahit xfatal inside the stderr blackout),
    // 64/65 (our synthetic deterministic codes), 132 (SIGILL -- the binary was
    // built for a newer CPU than the node; retrying on the same node class fails
    // identically), 134 (an abort matching neither grep pattern).
    withName: 'MCAAT_RUN|MCAAT_PHAGECURATE' {
        scratch          = { params.mcaat_scratch ?: false }
        containerOptions = { workflow.containerEngine in ['docker', 'podman'] ? '--entrypoint ""' : null }
        errorStrategy    = { task.exitStatus in ([104, 137, 140, 143] + (175..177)) ? 'retry' : 'finish' }
        maxRetries       = 2
    }

    // ========================================================================
    // Array detection
    // ========================================================================

    withName: 'MCAAT_RUN' {
        // Disk is input-proportional, not a flat constant: inputs span 1-100 GB
        // and `-m 1` is hard-coded, so every error k-mer is retained and the
        // graph tracks TOTAL SEQUENCED BASES rather than community complexity.
        // The 4x covers: outfile_prefix.bin (a full 2-bit re-encoding of every
        // read, ~0.29 B/base, transient), the SDBG shards (~2 B/edge),
        // cycles.txt, and the retained pruned graph.
        disk = {
            def bytes = (reads instanceof List) ? reads.sum { f -> f.size() } : reads.size()
            def gb    = (long) Math.ceil(bytes / 1_000_000_000d)
            ((50 + 4 * gb) * task.attempt).GB
        }

        publishDir = [
            [
                path: { "${params.outdir}/arrays/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: "mcaat/CRISPR_Arrays_*.txt",
                saveAs: { fn -> fn.tokenize('/')[-1] }
            ],
            [
                path: { "${params.outdir}/arrays/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: "mcaat/parameters.json",
                saveAs: { fn -> fn.tokenize('/')[-1] }
            ],
            [
                path: { "${params.outdir}/arrays/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: "mcaat.log",
                saveAs: { fn -> "${meta.id}.mcaat.log" }
            ],
            // Published as a DIRECTORY, never as a shard glob: the number of
            // graph.sdbg.<N> files equals --num_cpu_threads, so any enumerated
            // declaration breaks the moment task.cpus changes. Uses its own
            // publish mode so enabling this does not copy tens of GB.
            //
            // The `saveAs` is NOT cosmetic and must not be dropped: publishDir
            // preserves the path relative to the task work dir, so without it the
            // graph lands at <outdir>/arrays/<sample>/mcaat/graph. Graph re-entry
            // (samplesheet `sdbg` column) resolves the CRISPR_Arrays_*.txt as
            // SIBLINGS of the graph directory, and those are flattened to
            // <outdir>/arrays/<sample>/ by the blocks above. Flattening the graph
            // the same way is what makes that sibling convention -- and the guard
            // message in subworkflows/local/utils_nfcore_mcaat_pipeline, docs/usage.md
            // and docs/output.md -- true at the same time.
            [
                path: { "${params.outdir}/arrays/${meta.id}" },
                mode: params.graph_publish_mode,
                pattern: "mcaat/graph",
                saveAs: { fn -> fn.tokenize('/')[-1] },
                enabled: params.save_mcaat_graph
            ],
            // cycles.txt can be enormous (one line per cycle) and its line order
            // comes from unordered_map iteration, i.e. it is non-deterministic.
            [
                path: { "${params.outdir}/arrays/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: "mcaat/cycles.txt",
                saveAs: { fn -> fn.tokenize('/')[-1] },
                enabled: params.save_mcaat_cycles
            ]
        ]
    }

    // `*.provenance.tsv` is deliberately NOT published: it is a pure
    // intermediate, consumed by COHORT_SUMMARISE as its second input, and its
    // content is echoed into the published cohort_summary.tsv.
    withName: 'MCAAT_PARSEARRAYS' {
        ext.prefix = { "${meta.id}" }
        publishDir = [
            path: { "${params.outdir}/arrays/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.{arrays.tsv,spacers.fasta}"
        ]
    }

    // ========================================================================
    // Optional: phage / protospacer curation
    // ========================================================================

    withName: 'MCAAT_PHAGECURATE' {
        ext.prefix = { "${meta.id}" }
        // One pathological sample must never fail a cohort run: DepthLimitedSearch
        // is an uncapped recursive DFS whose maxDepth argument is silently
        // overridden per-cycle, and the cohort layer sits behind .collect().
        errorStrategy = { task.attempt <= 2 ? 'retry' : 'ignore' }
        maxRetries    = 2
        publishDir = [
            [
                path: { "${params.outdir}/phage/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: "*.phage_contigs.fasta"
            ],
            [
                path: { "${params.outdir}/phage/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: "*.log.gz",
                enabled: params.save_phage_log
            ]
        ]
    }

    // ========================================================================
    // Cohort aggregation and reporting
    // ========================================================================

    // The prefix here is NOT 'cohort_arrays': COHORT_SUMMARISE emits its own
    // annotated cohort_arrays.tsv into the very same ${params.outdir}/reports
    // directory, and two processes publishing the same basename into one
    // directory is a race whose winner depends on task completion order. This
    // file is the plain row-wise concatenation of the per-sample
    // *.arrays.tsv, so it is named for what it is.
    withName: 'CSVTK_CONCAT' {
        ext.prefix = 'cohort_arrays_concat'
        publishDir = [
            path: { "${params.outdir}/reports" },
            mode: params.publish_dir_mode,
            pattern: "*.tsv"
        ]
    }

    // SEQKIT_RMDUP is the SINGLE producer of reports/cohort_spacers.unique.fasta.
    // The input it is handed is the collectFile'd 'cohort_spacers.fasta', so the
    // module derives extension 'fasta' and emits '<prefix>.fasta' -- i.e. exactly
    // cohort_spacers.unique.fasta. That is the file docs/output.md documents
    // ("deduplicated on sequence with seqkit rmdup -s, each retained record keeps
    // the header of its first occurrence") and the file tests/.nftignore lists.
    // See the COHORT_SUMMARISE block below for the other half of this contract.
    withName: 'SEQKIT_RMDUP' {
        // '-s' de-duplicates by SEQUENCE, which is the only sensible key for a
        // pooled cohort spacer set (the headers carry per-sample provenance).
        ext.args   = '-s'
        ext.prefix = 'cohort_spacers.unique'
        publishDir = [
            path: { "${params.outdir}/reports" },
            mode: params.publish_dir_mode,
            pattern: "*.{fasta,fa,fasta.gz,fa.gz}"
        ]
    }

    // `--no-unique-fasta` and the TSV-only publish pattern are one fix, not two.
    //
    // bin/mcaat_aggregate.py writes cohort_spacers.unique.fasta unconditionally
    // unless that flag is set, and SEQKIT_RMDUP publishes a file of the SAME NAME
    // into this SAME directory. Two processes copying different content to one
    // publish path is a race whose winner is decided by task completion order, so
    // reports/cohort_spacers.unique.fasta would differ between otherwise identical
    // runs -- and the existence-only assertion in tests/pipeline/test_default.nf.test
    // would never catch it.
    //
    // SEQKIT_RMDUP wins because it is what the docs describe. Suppressing the
    // aggregator's copy cannot become a "Missing output file" failure: the module
    // declares that output `optional: true` precisely for this flag, and nothing
    // in workflows/mcaat.nf consumes COHORT_SUMMARISE.out.unique_spacers.
    //
    // With the FASTA gone, `cohort_*.tsv` is the whole publish surface. The
    // `mcaat_*_mqc.{tsv,yaml}` sections stay intentionally unmatched -- they reach
    // the user through MultiQC, not as loose files in reports/.
    withName: 'COHORT_SUMMARISE' {
        ext.args = '--no-unique-fasta'
        publishDir = [
            path: { "${params.outdir}/reports" },
            mode: params.publish_dir_mode,
            pattern: "cohort_*.tsv"
        ]
    }

    withName: 'MULTIQC' {
        ext.args = { params.multiqc_title ? "--title \"${params.multiqc_title}\"" : '' }
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
}
