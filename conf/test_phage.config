/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for the optional protospacer / phage curation stage
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Runs the minimal test dataset all the way through `mcaat phage-curate`.

    Use as follows:
        nextflow run RNABioInfo/mcaat-nf -profile test_phage,<docker/singularity> --outdir <OUTDIR>

    NOTE: this profile is EXCLUDED from the default nf-test tag set and runs as
    an opt-in shard. The stage is experimental (MCAAT v2.0.0 track).

    What it is here to prove, beyond "it runs":
      * the `rm -f phage/ContiguousPaths.fasta` guard -- MCAAT opens that file
        with std::ios::app and never truncates it, so a retry into a reused
        directory silently DOUBLES every record;
      * the in-task awk header rewrite -- MCAAT's emitted FASTA identifier is
        literally the reconstructed spacer nucleotide sequence, with no array id,
        no coordinates and no uniqueness guarantee, which is unusable in a cohort.

    NOTE -- THIS PROFILE CANNOT RUN YET, for the same reason as `-profile test`:
    `params.pipelines_testdata_base_path` points at
    https://raw.githubusercontent.com/RNABioInfo/mcaat-nf-testdata/main/, which
    has still to be created and populated. See CHANGELOG.md and docs/usage.md.

--------------------------------------------------------------------------------
*/

// The GitHub Actions budget. Wall time is the binding constraint for this stage,
// not memory: DepthLimitedSearch is an uncapped recursive DFS whose maxDepth
// argument is silently overridden per-cycle, followed by two O(n^2) std::search
// subpath filters with no candidate cap and no wall-clock budget. The test graph
// is tiny precisely so that this cannot bite inside a 1-hour job.
process {
    resourceLimits = [
        cpus  : 4,
        memory: '15.GB',
        time  : '1.h'
    ]
}

params {
    config_profile_name        = 'Phage curation test profile'
    config_profile_description = 'Minimal test dataset exercising the optional protospacer/phage curation stage'

    // Same input and same MCAAT settings as -profile test, so the array
    // detection task hash matches and the graph build is served from cache.
    input = params.pipelines_testdata_base_path + 'mcaat-nf/samplesheet/samplesheet.csv'

    subsample_reads = 2000
    subsample_seed  = 100

    // --- stage activation ----------------------------------------------------
    run_phage_curation = true

    // The phage stage consumes the SDBG. Set explicitly so the dependency is
    // visible in the profile; PIPELINE_INITIALISATION errors at launch if this
    // is false while run_phage_curation is true.
    mcaat_keep_graph = true

    // --- phage options -------------------------------------------------------
    // The only phage param that exists. Every other tunable in `mcaat
    // phage-curate` is either hard-coded (depth 50-then-overridden, max length
    // 2500, min length 500) or accepted-and-never-read (--beam-width, which
    // FindContiguousPathsFromGroupedPaths does not consult), so none of them is
    // exposed. The log is published here so CI can assert the run reached the
    // path-reconstruction phase rather than exiting early.
    save_phage_log = true
}
