/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running full-size tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a full-size pipeline test.

    Use as follows:
        nextflow run RNABioInfo/mcaat-nf -profile test_full,<docker/singularity> --outdir <OUTDIR>

    NOTE: this profile is NOT run in PR CI. It exists to be dispatched manually
    on real infrastructure, because it is the only way to obtain the empirical
    memory and wall-clock figures that conf/base.config has to be calibrated
    against -- MCAAT's own `--ram` flag does not cap memory,
    so `memory` is an OOM-kill ceiling that must be MEASURED, never derived.
    Run it with `-with-report` and follow the calibration procedure in
    docs/usage.md.

    NOTE -- THIS PROFILE CANNOT RUN YET, for the same reason as `-profile test`:
    `params.pipelines_testdata_base_path` points at
    https://raw.githubusercontent.com/RNABioInfo/mcaat-nf-testdata/main/, which
    has still to be created and populated. See CHANGELOG.md and docs/usage.md.

--------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Full test profile'
    config_profile_description = 'Full test dataset to check pipeline function'

    // Input data for a full-size test: a small number of modest, publicly
    // available gut metagenomes. Resolved from the pipeline test-data base path
    // rather than a hardcoded raw URL.
    input = params.pipelines_testdata_base_path + 'mcaat-nf/samplesheet/samplesheet_full.csv'

    // --- read QC -----------------------------------------------------------
    // No subsampling: the point of this profile is to observe the real resource
    // envelope on real read volumes. Note that `-m 1` is hard-coded in the graph
    // build, so every error k-mer is retained and RAM/disk scale with TOTAL
    // SEQUENCED BASES rather than with community complexity -- subsampling is
    // the pipeline's ONLY lever on that envelope, and it is deliberately off here.
    subsample_reads = null

    // phiX scrubbing is ON. The default `phix_reference` is
    // "${projectDir}/assets/phix174.fasta.gz" and that file IS shipped
    // (NC_001422.1, 5386 bp, public domain), so the
    // `file(params.phix_reference, checkIfExists: true)` channel construction in
    // subworkflows/local/read_qc/main.nf resolves cleanly. Real sequencing runs
    // are exactly where phiX spike-in carryover shows up, and every retained
    // phiX read is an error k-mer the graph build has to carry, so a full-size
    // run is the profile that most needs this on.
    remove_phix     = true

    // --- MCAAT -------------------------------------------------------------
    // Keep the graph on disk in the work directory so the optional stage can be
    // re-run against this cohort without paying for the build again. For cohorts
    // larger than ~100 samples, set --mcaat_keep_graph false instead: the graph
    // is the single largest residue per sample.
    mcaat_keep_graph = true
    prune_graph      = true
    save_mcaat_graph = false
    save_mcaat_cycles = false

    // --- optional stages ---------------------------------------------------
    // Phage curation stays OFF: it is experimental (MCAAT v2.0.0 track) and
    // wall-time-unbounded, which would confound the very resource measurements
    // this profile exists to produce.
    run_phage_curation = false

    // --- reporting ---------------------------------------------------------
    multiqc_title = 'mcaat-nf full-size test'
}
