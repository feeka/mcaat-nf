/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config applied to every nf-test invocation
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

    Referenced from nf-test.config as `configFile`. It is layered *on top of*
    whichever -profile the test selects, so anything set here wins over
    conf/test.config.

    The nf-core `nf_test_content` lint rule requires BOTH
    `modules_testdata_base_path` and `pipelines_testdata_base_path` to be
    defined in this file.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    // Base path for shared nf-core/modules test data (used by the vendored
    // nf-core module tests and by any module fixture we borrow).
    modules_testdata_base_path   = 's3://ngi-igenomes/testdata/nf-core/modules/'

    // Base path for pipeline test data. Resolves to the `main` branch of
    // RNABioInfo/mcaat-nf-testdata, e.g.
    //   ${pipelines_testdata_base_path}mcaat-nf/reads/gut_A_L001_R1.fastq.gz
    // Never hardcode a raw.githubusercontent URL in a test or a test profile;
    // always build the path from this param.
    //
    // WARNING: RNABioInfo/mcaat-nf-testdata DOES NOT EXIST YET. It has to be
    // created and populated (samplesheets, synthetic read libraries, the
    // graph-re-entry fixture) before `-profile test` can resolve anything.
    // Until then every test that launches the pipeline fails while staging the
    // samplesheet, with a 404 from raw.githubusercontent.com. This is stated in
    // CHANGELOG.md and docs/usage.md as well; it is not a solved problem.
    pipelines_testdata_base_path = 'https://raw.githubusercontent.com/RNABioInfo/mcaat-nf-testdata/main/'

    // Keep the test runs hermetic and fast.
    validate_params              = true
    monochrome_logs              = true
}

/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Resource ceiling
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

    This is the GitHub Actions standard runner budget and it is a HARD design
    constraint, not a suggestion: conf/base.config asks for 72.GB / 8 cpus /
    16.h for `process_mcaat_run`, and without this ceiling every MCAAT task
    would be rejected as unschedulable on a 4-cpu / 16-GB runner.

    `resourceLimits` caps rather than overrides, so the retry ladders in
    conf/base.config still express the right intent for real clusters while
    collapsing to the runner budget here.

    NOTE: capping cpus at 4 also caps the SDBG shard count at 4
    (graph.sdbg.<N> count == --num_cpu_threads) and caps the per-thread visited
    bitset allocation in CycleFinder at 4 x edges/8 bytes. Both are why the
    test dataset must be tiny.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {
    resourceLimits = [
        cpus  : 4,
        memory: '15.GB',
        time  : '1.h',
    ]

    // MCAAT's `disk` directive in conf/modules.config is input-proportional and
    // means nothing on a GitHub runner, where the local executor ignores it
    // anyway. Null it out so it cannot participate in scheduling decisions on a
    // developer's laptop running the test suite under a real executor.
    withName: 'MCAAT_RUN' {
        disk = null
    }
}

// Apptainer/Singularity image conversion of the MCAAT image is slow; do not
// let nf-test's own timeout race it.
singularity {
    pullTimeout = '60 min'
}
apptainer {
    pullTimeout = '60 min'
}

// Deterministic, greppable logs for CI failure triage. MCAAT writes its real
// diagnostics to STDOUT (megahit's stderr is dup2'd to /dev/null inside the
// tool), so .command.out is the file that matters when a task fails.
dag {
    enabled = false
}
