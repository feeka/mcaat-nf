/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    RNABioInfo/mcaat-nf  --  nf-test configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

    The values `testsDir`, `workDir`, `configFile` and the `ignore` list are
    checked verbatim by the nf-core `nf_test_content` lint rule. Do not
    "tidy" them.

    SYNTAX: everything inside `config { }` is a METHOD CALL, not an assignment.
    Write `testsDir "."`, never `testsDir = "."`. The closure delegates to
    nf-test's config builder, which exposes testsDir/workDir/configFile/
    profile/ignore/triggers as methods; an `=` statement resolves against the
    script binding instead and is silently discarded, at which point nf-test
    falls back to its defaults (testsDir `tests`, no configFile, no profile,
    no ignore list) and this whole file stops doing anything.

    `testsDir "."` means nf-test discovers every *.nf.test in the repository,
    including the per-module tests under modules/local/**/tests/. The `ignore`
    list then removes the vendored nf-core module and subworkflow tests, which
    are maintained (and CI-ed) upstream in nf-core/modules and which we must
    never hand-edit or snapshot here.
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

config {

    testsDir "."
    workDir System.getenv("NFT_WORKDIR") ?: ".nf-test"
    configFile "tests/nextflow.config"
    profile "test"

    ignore 'modules/nf-core/**/tests/*', 'subworkflows/nf-core/**/tests/*'

    // Files that, when changed, invalidate *every* test rather than only the
    // tests whose own sources changed. `nf-test test --changed-since` uses
    // this list; without it a change to e.g. bin/mcaat_parse_arrays.py would
    // not re-run the pipeline-level test that consumes it.
    triggers '.github/workflows/nf-test.yml',
             'assets/schema_input.json',
             'bin/*',
             'conf/base.config',
             'conf/modules.config',
             'conf/test.config',
             // The opt-in profiles are triggers too: tests/pipeline/test_phage.nf.test
             // and tests/pipeline/test_graph_reentry.nf.test are the contract for
             // these two files and must re-run whenever either changes.
             'conf/test_graph.config',
             'conf/test_phage.config',
             'nextflow.config',
             'nextflow_schema.json',
             'nf-test.config',
             'tests/.nftignore',
             'tests/nextflow.config'

    plugins {
        // nft-utils supplies getAllFilesFromDir() and removeNextflowVersion(),
        // both used by tests/pipeline/*.nf.test.
        //
        // The directory walker is called getAllFilesFromDir -- there is no
        // getAllFilesFromPath, and an earlier revision of this comment claimed
        // the opposite. That claim cost a whole test: the misspelt call sat in a
        // `then {}` block ahead of assertAll(), so it raised
        // groovy.lang.MissingMethodException and every assertion after it was
        // dead code. Options are passed as NAMED arguments, which Groovy gathers
        // into a leading Map: relative, includeDir, ignore, ignoreFile.
        //
        // The version is PINNED. An unpinned plugin turns an upstream release
        // into a surprise red CI on an unchanged repository, and the named-
        // argument shapes above are only guaranteed for the pinned version.
        load "nft-utils@1.0.0"
    }
}
