root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_size = 4
indent_style = space

[*.{md,yml,yaml,html,css,scss,js,cff}]
indent_size = 2

# These files are edited and tested upstream in nf-core/modules
[/modules/nf-core/**]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset

[/subworkflows/nf-core/**]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset

# Auto-generated by `nf-core pipelines create` / `nf-core modules install`.
# Never hand-edit, therefore never lint.
[/conf/containers_*.config]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset

[/assets/email_template.txt]
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset

[/assets/sendmail_template.txt]
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset

# MultiQC custom-content headers are position sensitive and the fixture
# files under tests/ intentionally reproduce MCAAT's byte-exact output
# (8 leading spaces + TAB separated spacer lines, trailing blank line
# terminating each array block). Reformatting them silently breaks the
# parser tests they exist to protect.
[/tests/fixtures/**]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset

[/assets/*_mqc.tsv]
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset

# Binary / vendored assets
[/docs/images/*]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset

[/assets/*.gz]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset

# Snapshots are machine generated by nf-test.
[**/*.snap]
charset = unset
end_of_line = unset
insert_final_newline = unset
trim_trailing_whitespace = unset
indent_style = unset
indent_size = unset

[/.github/CONTRIBUTING.md]
trim_trailing_whitespace = unset

[/.github/workflows/branch.yml]
indent_size = unset
